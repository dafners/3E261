@startuml diagrama

class Guardia {
  - Camara camara[]
  - Mascara mascara
  - MusicBox musicBox
  - Luz luz[]
  - Energia energia
  + monitorear(Camara)
  + poner(Mascara)
  + escuchar(MusicBox)
  + encender(Luz)
  + verificar(Energia)
}

class Personaje

class Animatronico {
  - Pasillo pasillo
  - Ventilacion ventilacion
  - JumpScare jumpScare
  + mover(Pasillo)
  + mover(Ventilacion)
  + asustar(JumpScare)
}

